# ── Database — Option A: Supabase (cloud) ────────────────────────
# Paste your Supabase connection string here.
# Find it in: Supabase Dashboard → Project → Settings → Database → Connection string → URI
# Use the "Transaction" pooler URL for best performance.
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# ── Database — Option B: local PostgreSQL (Docker / native) ──────
# Comment out DATABASE_URL above and uncomment these instead:
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=ems_dashboard
# POSTGRES_USER=ems
# POSTGRES_PASSWORD=ems_secure_2026

# ── Express.js App ───────────────────────────────────────────────
PORT=3001

# ── MQTT Broker ──────────────────────────────────────────────────
# Point to your local Mosquitto broker (installed separately on Windows)
MQTT_BROKER=mqtt://localhost:1883

# ── JWT Auth ─────────────────────────────────────────────────────
# Change this to a long random string in production
JWT_SECRET=ems_jwt_secret_change_in_production

# ── Sensor Simulator ─────────────────────────────────────────────
# Set to true to run without physical sensors — seeds 7 days of
# historical data on first start, then sends live readings every 30 s.
# Disable when real hardware (PZEM-004T, SHT40, etc.) is connected.
ENABLE_SIMULATOR=true

# ── Push notifications for the mobile app (optional) ─────────────
# Shared secret protecting POST /api/cron/dispatch-alerts. Vercel Cron sends it
# automatically as a Bearer token when set here. Generate a long random string.
CRON_SECRET=

# Firebase service-account JSON for sending FCM pushes (server side).
# Paste the full service-account JSON on one line, OR a base64-encoded version.
# Get it from: Firebase Console → Project Settings → Service accounts →
# Generate new private key. Mark as a SECRET in the deploy platform.
# Leave empty to disable push (the app still works without it).
FCM_SERVICE_ACCOUNT=
